generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Reservation {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  phone     String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}